root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = false
indent_style = space
indent_size = 2

[{*.kt, *.nim, *.nims, *.nimble, *.gradle, *.pyi, *.py, *.sss, *.ts, *.pug, *.yaml, *.json, *.go}]
insert_final_newline = true
trim_trailing_whitespace = true

[{*.py, *.pyi}]
indent_size = 4

[{*.puml, *.md}]
trim_trailing_whitespace = false
